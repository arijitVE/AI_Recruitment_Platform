# Database URL (Defaulting to SQLite async; switch to Neon PostgreSQL connection string: postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?ssl=require)
DATABASE_URL=sqlite+aiosqlite:///./recruitment_platform.db

# Supabase Storage Configuration
# SUPABASE_KEY: the anon/publishable key (safe to expose to frontend)
# SUPABASE_SERVICE_KEY: the service_role key from Supabase Dashboard → Project Settings → API
#   This key bypasses Row Level Security (RLS) and is REQUIRED for backend file uploads.
#   Keep it secret — never expose it to the browser.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_anon_publishable_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=resumes

# OpenAI API Key for embeddings and structured LLM calls
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Store Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=recruitment-platform

# Storage configuration for local fallback or temp files
STORAGE_PATH=./data/resumes
MAX_UPLOAD_BYTES=10485760

# Comma-separated browser origins for the HR/candidate MVP frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Never enable outside isolated local demos/tests. Allows mock LLM and in-memory vectors.
ALLOW_DEVELOPMENT_FALLBACKS=false
