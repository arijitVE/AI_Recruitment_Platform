# Database URL (Defaulting to SQLite async for easy out-of-the-box local setup without external deps; switch to asyncpg postgresql+asyncpg://user:pass@localhost:5432/db for production)
DATABASE_URL=sqlite+aiosqlite:///./recruitment_platform.db

# OpenAI API Key for embeddings and structured LLM calls
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Store Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=recruitment-platform

# Storage configuration for uploaded resume files
STORAGE_PATH=./data/resumes
MAX_UPLOAD_BYTES=10485760

# Comma-separated browser origins for the HR/candidate MVP frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Never enable outside isolated local demos/tests. Allows mock LLM and in-memory vectors.
ALLOW_DEVELOPMENT_FALLBACKS=false
